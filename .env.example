# Judy App — Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# ── Required ────────────────────────────────────────────────

# Database connection (Prisma via libSQL adapter).
# Production MUST set this — the app refuses to start with a local file DB in production.
# Examples:
#   Local dev:      file:prisma/dev.db
#   Turso (hosted): libsql://your-db-name.turso.io
DATABASE_URL="file:prisma/dev.db"

# Auth token for hosted libSQL databases (e.g. Turso). Not needed for local files.
# DATABASE_AUTH_TOKEN=

# Auth.js session encryption secret. Generate with: openssl rand -base64 32
AUTH_SECRET=your_generated_secret_here

# ── AI & Google APIs (features degrade gracefully if unset) ─

# Google Generative Language (Gemini): AI suggestions + Travel Daddy chat
GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps Platform: Places autocomplete/details + Weather.
# Enable in Cloud Console: Places API (New), Geocoding API, Weather API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# HeyGen Interactive Avatar (optional). If unset, the app shows the local
# 3D Travel Daddy placeholder instead of the streamed avatar.
# HEYGEN_API_KEY=

# Rigged GLB avatar lip sync (optional, Swarm J7 stage 2).
# Without these, the GLB avatar still shows and "talks" using approximate
# jaw movement paced to the browser's own speechSynthesis — no credentials
# needed for that. These two only matter once you want accurate,
# audio-driven lip sync via Rhubarb Lip Sync (https://github.com/DanielSWolf/rhubarb-lip-sync):
#
# Path to the Rhubarb binary on this host. Defaults to the local dev path
# (/Users/robert/.local/opt/rhubarb-1.14.0/rhubarb) if unset — production
# (VPS/Hostinger) needs the binary installed there and this var pointed at it.
# RHUBARB_BIN_PATH=

# No TTS provider is chosen yet (src/lib/avatar/tts.ts throws until one is
# wired in). Whichever is picked must return WAV/PCM audio — Rhubarb analyzes
# the waveform itself, so no viseme API is required from the provider.
# TTS_PROVIDER=

# Hermes producer relay (optional, disabled by default).
# Enable only after setting an HTTPS bridge base URL and producer secret.
HERMES_EDGE_BRIDGE_ENABLED=false
# HERMES_EDGE_BRIDGE_URL=https://relay.example.com
# HERMES_EDGE_PRODUCER_SECRET=
# Request timeout in milliseconds. Allowed range: 100-10000; default: 5000.
# HERMES_EDGE_BRIDGE_TIMEOUT_MS=5000

# ── Contact form email notifications (optional) ─────────────
# If unset, contact submissions are still saved to the database;
# only the email notification is skipped.
# Use a transactional provider (Postmark, SES, SendGrid SMTP relay).
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# ADMIN_EMAIL=

# ── Runtime ─────────────────────────────────────────────────
# PORT is injected by the host (Hostinger/Passenger); defaults to 3000.
# NODE_ENV is set by the platform/npm scripts.
