# Judy App Environment Variables

# Google Maps / Places / Weather API Key
# Enable these in Google Cloud Console: Places API (New), Geocoding API,
# Maps JavaScript API, Street View Static API, Weather API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Generative Language (Gemini) API Key
# Enable: Generative Language API
GEMINI_API_KEY=your_gemini_api_key_here

# HeyGen Interactive Avatar (https://www.heygen.com/)
HEYGEN_API_KEY=your_heygen_api_key_here

# Database
DATABASE_URL="file:./dev.db"

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
