# Judy App — Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# ── Required ────────────────────────────────────────────────

# Database connection (Prisma via libSQL adapter).
# Production MUST set this — the app refuses to start with a local file DB in production.
# Examples:
#   Local dev:      file:prisma/dev.db
#   Turso (hosted): libsql://your-db-name.turso.io
DATABASE_URL="file:prisma/dev.db"

# Auth token for hosted libSQL databases (e.g. Turso). Not needed for local files.
# DATABASE_AUTH_TOKEN=

# Auth.js session encryption secret. Generate with: openssl rand -base64 32
AUTH_SECRET=your_generated_secret_here

# Public base URL of the deployment. Used by sitemap.ts and for the Stripe
# post-checkout redirect. Defaults to http://localhost:3000 when unset —
# production MUST set this or checkout will redirect users to localhost.
# NEXT_PUBLIC_APP_URL=https://judy.lgbt

# ── AI & Google APIs (features degrade gracefully if unset) ─

# Google Generative Language (Gemini): AI suggestions + Judy Pierre chat,
# memory captions and image edits, SEO destination generation.
GEMINI_API_KEY=your_gemini_api_key_here
# Optional model overrides; production defaults are shown.
GEMINI_TEXT_MODEL=gemini-3.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

# Google Maps Platform: Places autocomplete/details + Weather.
# Enable in Cloud Console: Places API (New), Geocoding API, Weather API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# HeyGen Interactive Avatar (optional). If unset, the app shows the local
# GLB Judy Pierre avatar instead of the streamed avatar.
# HEYGEN_API_KEY=
#
# Optional — select a specific HeyGen avatar/voice instead of your account
# default. Only applied when set; omitting both preserves prior behavior.
# HEYGEN_AVATAR_ID=
# HEYGEN_VOICE_ID=

# Rigged GLB avatar lip sync (optional, Swarm J7 stage 2).
# Without these, the GLB avatar still shows and "talks" using approximate
# jaw movement paced to the browser's own speechSynthesis — no credentials
# needed for that. These matter once you want accurate, audio-driven lip
# sync via Rhubarb Lip Sync (https://github.com/DanielSWolf/rhubarb-lip-sync):
#
# Path to the Rhubarb binary on this host. Defaults to the local dev path
# (/Users/robert/.local/opt/rhubarb-1.14.0/rhubarb) if unset — production
# (VPS/Hostinger) needs the binary installed there and this var pointed at it.
# RHUBARB_BIN=

# TTS provider selection for stage-2 lip sync. Currently supported: "elevenlabs".
# Leave unset to stay on stage-1 (browser speechSynthesis + approximate jaw).
# TTS_PROVIDER=elevenlabs
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# Optional — defaults to eleven_multilingual_v2 (needed for non-English dubbing).
# ELEVENLABS_MODEL_ID=
#
# Per-voice provider overrides. src/lib/voice/catalog.ts defines the
# application-level voice IDs the client is allowed to pick from; each may be
# mapped to a specific provider voice with a variable named after it. When
# unset, the adapter falls back to the default provider voice above.
# NOTE: the TRAVEL_DADDY_* names are legacy identifiers kept for compatibility
# with preferences already persisted in the database — the companion is now
# Judy Pierre in all user-facing copy. Do not rename without a data migration.
# ELEVENLABS_VOICE_TRAVEL_DADDY_CLASSIC_ES=
# HEYGEN_VOICE_TRAVEL_DADDY_CLASSIC_ES=

# ── Payments (Stripe) ───────────────────────────────────────
# Judy can assemble a custom travel package during a conversation and create a
# Stripe product + price + payment link for it (see src/lib/stripe/client.ts,
# invoked as a tool from /api/avatar/chat). When unset, the helper returns a
# mock payment link and logs a warning — local dev never contacts Stripe.
# Post-checkout, Stripe redirects to ${NEXT_PUBLIC_APP_URL}/itinerary?success=true
# STRIPE_SECRET_KEY=

# ── RAG knowledge base ──────────────────────────────────────
# Used by `npm run rag:feeds` only; `npm run rag:ingest` needs neither.
# Comma-separated feed URLs to pull into the knowledge base.
# RAG_FEEDS_URLS=
# Comma-separated hostname allowlist. Feeds whose host is not listed are
# refused — keep this tight, the ingest fetches remote content.
# RAG_FEEDS_ALLOWLIST=

# Admin-only GLB Avatar Manager (/admin/avatar).
# Comma-separated, case-insensitive email allowlist. If unset, ADMIN_EMAIL
# below is accepted as a backwards-compatible single administrator.
# AVATAR_ADMIN_EMAILS=owner@example.com
#
# Persistent directory for uploaded avatar versions and the active manifest.
# Production must point this outside the Git deployment checkout so a deploy
# cannot erase uploads. The app creates the directory when first activated.
# AVATAR_STORAGE_DIR=/home/u876474286/judy-avatar-assets

# Hermes producer relay (optional, disabled by default).
# Enable only after setting an HTTPS bridge base URL and producer secret.
HERMES_EDGE_BRIDGE_ENABLED=false
# HERMES_EDGE_BRIDGE_URL=https://relay.example.com
# HERMES_EDGE_PRODUCER_SECRET=
# Request timeout in milliseconds. Allowed range: 100-10000; default: 5000.
# HERMES_EDGE_BRIDGE_TIMEOUT_MS=5000

# ── Contact form email notifications (optional) ─────────────
# If unset, contact submissions are still saved to the database;
# only the email notification is skipped.
# Use a transactional provider (Postmark, SES, SendGrid SMTP relay).
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# ADMIN_EMAIL=

# ── Runtime ─────────────────────────────────────────────────
# PORT is injected by the host (Hostinger/Passenger); defaults to 3000.
# NODE_ENV is set by the platform/npm scripts.
